{
  "name": "frontendmaxxing",
  "version": "1.0.0",
  "description": "481 standalone CSS + JS snippets for frontend design. Vanilla, zero-dep, copy-paste, framework-agnostic.",
  "keywords": [
    "ui",
    "components",
    "snippets",
    "css",
    "javascript",
    "vanilla",
    "framework-agnostic",
    "no-dependencies",
    "ai-ui",
    "gradients",
    "shaders",
    "webgl",
    "three.js",
    "animations",
    "design-system",
    "copy-paste",
    "frontend"
  ],
  "homepage": "https://github.com/sirdath/frontendmaxxing#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sirdath/frontendmaxxing.git"
  },
  "bugs": {
    "url": "https://github.com/sirdath/frontendmaxxing/issues"
  },
  "license": "MIT",
  "author": "frontendmaxxing contributors",
  "files": [
    "3d/",
    "ai/",
    "animations/",
    "backgrounds/",
    "blocks/",
    "borders/",
    "colors/",
    "components/",
    "cursor/",
    "data-viz/",
    "effects/",
    "feedback/",
    "gsap/",
    "interactions/",
    "layout/",
    "media/",
    "micro/",
    "mobile/",
    "responsive/",
    "scroll/",
    "shaders/",
    "structure/",
    "svg/",
    "taste/",
    "transitions/",
    "typography/",
    "utils/",
    "demo/",
    "AGENTS.md",
    "INDEX.md",
    "*.skill.md",
    "LICENSE",
    "README.md"
  ],
  "type": "commonjs",
  "main": "./utils/dom.js",
  "scripts": {
    "demo": "echo 'Open demo/index.html in your browser — no build step needed.'",
    "stats": "echo 'CSS:' && find . -name \"*.css\" -not -path \"./node_modules/*\" -not -path \"./demo/*\" | wc -l && echo 'JS:' && find . -name \"*.js\" -not -path \"./node_modules/*\" -not -path \"./demo/*\" | wc -l",
    "audit": "node tools/audit.js",
    "audit:strict": "node tools/audit.js --strict",
    "test": "node mcp-server/test.js",
    "smoke": "node tools/render-smoke.mjs",
    "smoke:dev": "CONCURRENCY=1 node tools/render-smoke.mjs --only",
    "smoke:safe": "CONCURRENCY=2 node tools/render-smoke.mjs",
    "smoke:ci": "HARNESS_SOFTWARE=1 node tools/render-smoke.mjs",
    "smoke:setup": "cd tools && npm install",
    "verify": "node tools/audit.js && node mcp-server/test.js",
    "verify:full": "node tools/audit.js && node mcp-server/test.js && node tools/render-smoke.mjs"
  },
  "engines": {
    "node": ">=14"
  },
  "private": false,
  "sideEffects": false
}
